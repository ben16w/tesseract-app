[Unit]
Description=MCP Proxy Service
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=/opt/mcp-proxy/mcp-proxy --config /opt/mcp-proxy/config.json -expand-env=true
User={{ tesseract_username }}
Group={{ tesseract_username }}
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
