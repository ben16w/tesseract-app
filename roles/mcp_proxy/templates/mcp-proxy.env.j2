{% set path_entries = [] %}
{% if mcp_proxy_npm_packages_to_install | default([]) | length > 0 %}
{%   set path_entries = path_entries + [mcp_proxy_npm_prefix ~ '/node_modules/.bin'] %}
{% endif %}
{% if mcp_proxy_environment.PATH is defined %}
{%   set path_entries = path_entries + [mcp_proxy_environment.PATH] %}
{% else %}
{%   set path_entries = path_entries + ['/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin'] %}
{% endif %}
PATH={{ path_entries | join(':') | quote }}
{% for item in mcp_proxy_environment | dict2items | rejectattr('key', 'equalto', 'PATH') | sort(attribute='key') %}
{{ item.key }}={{ item.value | quote }}
{% endfor %}
